			function detectCountry(): string {
				try {
					const tz = Intl.DateTimeFormat().resolvedOptions().timeZone;
					return TZ_COUNTRY[tz] ?? '';
				} catch {
					return '';
				}
			}

			function applyRegionFilter(country: string) {
				// Reset all region-filtered cards first
				document.querySelectorAll<HTMLElement>('[data-regions]').forEach(card => {
					card.style.display = '';
				});
				document.querySelectorAll<HTMLElement>('.category').forEach(section => {
					section.style.display = '';
				});

				if (!country) return; // no country = show everything

				document.querySelectorAll<HTMLElement>('[data-regions]').forEach(card => {
					const regions = card.dataset.regions;
					if (!regions) return; // no attribute = global app, always visible
					card.style.display = regions.split(',').includes(country) ? '' : 'none';
				});

				// Hide category sections that end up with no visible cards
				document.querySelectorAll<HTMLElement>('.category').forEach(section => {
					const grid = section.querySelector<HTMLElement>('.grid');
					if (!grid) return;
					const hasVisible = [...grid.querySelectorAll<HTMLElement>('.card')]
						.some(c => c.style.display !== 'none');
					section.style.display = hasVisible ? '' : 'none';
				});
			}

			const regionOverride = localStorage.getItem('tesflix-region');
			const detectedCountry = regionOverride !== null ? regionOverride : detectCountry();
			applyRegionFilter(detectedCountry);
			applyCountryActive(detectedCountry);

			// ── Custom Apps ──
			const CUSTOM_KEY = 'tesflix-custom-apps';
			const YOUTUBE_REDIRECT = 'https://www.youtube.com/redirect?q=';

			interface CustomApp {
				id: string;
				name: string;
				url: string;
				logo: string;
				color: string;
				category: string;
				fullscreen: boolean;
			}

			function loadCustomApps(): CustomApp[] {
				try { return JSON.parse(localStorage.getItem(CUSTOM_KEY) || '[]'); }
				catch { return []; }
			}

			function saveCustomApps(apps: CustomApp[]) {
				localStorage.setItem(CUSTOM_KEY, JSON.stringify(apps));
			}

			function createCustomCard(app: CustomApp): HTMLAnchorElement {
				const a = document.createElement('a');
				a.href = app.fullscreen ? `${YOUTUBE_REDIRECT}${encodeURIComponent(app.url)}` : app.url;
				a.target = '_blank';
				a.rel = 'noopener noreferrer';
				a.className = 'card';
				a.style.setProperty('--app-color', app.color);
				a.dataset.customId = app.id;

				const spotlight = document.createElement('span');
				spotlight.className = 'spotlight';
				spotlight.setAttribute('aria-hidden', 'true');

				const borderGlow = document.createElement('span');
				borderGlow.className = 'border-glow';
				borderGlow.setAttribute('aria-hidden', 'true');

				const inner = document.createElement('div');
				inner.className = 'card-inner';

				const iconWrap = document.createElement('div');
				iconWrap.className = 'icon-wrap';

				const fallback = document.createElement('span');
				fallback.className = 'icon-fallback';
				fallback.style.color = app.color;

				if (app.logo) {
					const img = document.createElement('img');
					img.src = app.logo;
					img.alt = `${app.name} logo`;
					img.width = 80;
					img.height = 80;
					img.onerror = () => { img.style.display = 'none'; fallback.style.display = 'flex'; };
					iconWrap.appendChild(img);
					fallback.style.display = 'none';
				} else {
					fallback.style.display = 'flex';
				}
				fallback.textContent = app.name[0]?.toUpperCase() ?? '?';
				iconWrap.appendChild(fallback);

				const appName = document.createElement('p');
				appName.className = 'app-name';
				appName.textContent = app.name;

				inner.appendChild(iconWrap);
				inner.appendChild(appName);

				const deleteBtn = document.createElement('button');
				deleteBtn.className = 'card-delete';
				deleteBtn.setAttribute('aria-label', `Delete ${app.name}`);
				deleteBtn.innerHTML = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M18 6 6 18M6 6l12 12"/></svg>`;
				deleteBtn.addEventListener('click', (e) => {
					e.preventDefault();
					e.stopPropagation();
					deleteCustomApp(app.id);
				});

				a.appendChild(spotlight);
				a.appendChild(borderGlow);
				a.appendChild(inner);
				a.appendChild(deleteBtn);
				attachSpotlight(a);
				return a;
			}

			function getOrCreateCategorySection(categoryName: string): HTMLElement {
				let section = container.querySelector<HTMLElement>(`[data-category="${CSS.escape(categoryName)}"]`);
				if (section) return section;

				section = document.createElement('section');
				section.className = 'category';
				section.dataset.category = categoryName;

				const title = document.createElement('h2');
				title.className = 'category-title';
				title.innerHTML = `<span class="drag-handle" aria-hidden="true"><svg viewBox="0 0 24 24" fill="currentColor"><circle cx="9" cy="5" r="1.5"/><circle cx="15" cy="5" r="1.5"/><circle cx="9" cy="12" r="1.5"/><circle cx="15" cy="12" r="1.5"/><circle cx="9" cy="19" r="1.5"/><circle cx="15" cy="19" r="1.5"/></svg></span>`;
				title.appendChild(document.createTextNode(categoryName));

				const grid = document.createElement('div');
				grid.className = 'grid';

				section.appendChild(title);
				section.appendChild(grid);
				container.appendChild(section);
				initSectionDrag(section);
				return section;
			}

			function renderCustomApps() {
				// Remove existing custom cards
				document.querySelectorAll<HTMLElement>('[data-custom-id]').forEach(el => el.remove());
				// Remove empty custom-only sections
				document.querySelectorAll<HTMLElement>('.category[data-custom-section]').forEach(el => el.remove());

				const apps = loadCustomApps();
				apps.forEach(app => {
					const section = getOrCreateCategorySection(app.category);
					if (!section.dataset.customSection) {
						// Mark if this section was created just for custom apps (no static apps)
						const isNewSection = !section.querySelector('.card:not([data-custom-id])');
						if (isNewSection) section.dataset.customSection = 'true';
					}
					section.querySelector('.grid')?.appendChild(createCustomCard(app));
				});
			}

			function deleteCustomApp(id: string) {
				const apps = loadCustomApps().filter(a => a.id !== id);
				saveCustomApps(apps);
				renderCustomApps();
			}

			renderCustomApps();

			// ── Add App Form ──
			document.getElementById('btn-add-app')?.addEventListener('click', () => {
				// Populate category select from current DOM
				const select = document.getElementById('app-category') as HTMLSelectElement;
				select.innerHTML = '';
				getSections().forEach(section => {
					const name = section.dataset.category!;
					const opt = document.createElement('option');
					opt.value = name;
					opt.textContent = name;
					select.appendChild(opt);
				});
				const newOpt = document.createElement('option');
				newOpt.value = '__new__';
				newOpt.textContent = '+ New category…';
				select.appendChild(newOpt);

				// Reset form
				(document.getElementById('add-app-form') as HTMLFormElement).reset();
				(document.getElementById('app-color') as HTMLInputElement).value = '#e50914';
				(document.getElementById('new-cat-row') as HTMLElement).style.display = 'none';
				(document.getElementById('form-error') as HTMLElement).style.display = 'none';
				const fsCheckbox = document.getElementById('app-fullscreen') as HTMLInputElement;
				fsCheckbox.checked = true;
				(document.getElementById('app-fullscreen-hint') as HTMLElement).textContent = 'Opens via YouTube redirect (fullscreen in Tesla)';
				openModal('modal-add-app');
			});

			document.getElementById('app-fullscreen')?.addEventListener('change', function(this: HTMLInputElement) {
				(document.getElementById('app-fullscreen-hint') as HTMLElement).textContent = this.checked
					? 'Opens via YouTube redirect (fullscreen in Tesla)'
					: 'Opens directly in the browser (normal tab)';
			});

			document.getElementById('app-category')?.addEventListener('change', (e) => {
				const val = (e.target as HTMLSelectElement).value;
				(document.getElementById('new-cat-row') as HTMLElement).style.display = val === '__new__' ? '' : 'none';
			});

			document.getElementById('add-app-form')?.addEventListener('submit', (e) => {
				e.preventDefault();
				const name = (document.getElementById('app-name') as HTMLInputElement).value.trim();
				const rawUrl = (document.getElementById('app-url') as HTMLInputElement).value.trim();
				const logo = (document.getElementById('app-logo') as HTMLInputElement).value.trim();
				const color = (document.getElementById('app-color') as HTMLInputElement).value;
				const catSelect = (document.getElementById('app-category') as HTMLSelectElement).value;
				const newCat = (document.getElementById('app-new-cat') as HTMLInputElement).value.trim();
				const errorEl = document.getElementById('form-error') as HTMLElement;

				const category = catSelect === '__new__' ? newCat : catSelect;

				if (!name) { showFormError('Please enter a name.'); return; }
				if (!rawUrl) { showFormError('Please enter a URL.'); return; }
				if (!category) { showFormError('Please enter a category name.'); return; }

				let url = rawUrl;
				if (!url.startsWith('http://') && !url.startsWith('https://')) url = 'https://' + url;
				try { new URL(url); } catch { showFormError('Invalid URL.'); return; }

				errorEl.style.display = 'none';

				const appFullscreen = (document.getElementById('app-fullscreen') as HTMLInputElement).checked;
				const app: CustomApp = {
					id: crypto.randomUUID(),
					name, url, logo, color, category, fullscreen: appFullscreen,
				};
				const apps = loadCustomApps();
				apps.push(app);
				saveCustomApps(apps);
				renderCustomApps();
				closeModal('modal-add-app');
			});

			function showFormError(msg: string) {
				const el = document.getElementById('form-error') as HTMLElement;
				el.textContent = msg;
				el.style.display = 'block';
			}
		</script>
	</body>
</html>

<style is:global>
	*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

	:root {
		--bg: #0A0A0F;
		--surface: rgba(255, 255, 255, 0.04);
		--border: rgba(255, 255, 255, 0.08);
		--text: #F8FAFC;
		--muted: #64748b;
		--red: #E50914;
	}

	body {
		background-color: var(--bg);
		color: var(--text);
		font-family: var(--font-geist), system-ui, sans-serif;
		min-height: 100dvh;
		-webkit-font-smoothing: antialiased;
		overflow-x: hidden;
	}

	::-webkit-scrollbar { width: 4px; }
	::-webkit-scrollbar-track { background: transparent; }
	::-webkit-scrollbar-thumb { background: rgba(255, 255, 255, 0.15); border-radius: 2px; }
	::-webkit-scrollbar-thumb:hover { background: rgba(255, 255, 255, 0.25); }

	/* ── Ambient background ── */
	.ambient {
		position: fixed;
		inset: 0;
		pointer-events: none;
		z-index: 0;
		overflow: hidden;
	}

	.blob {
		position: absolute;
		border-radius: 50%;
		filter: blur(120px);
		opacity: 0.18;
	}

	.blob-1 {
		width: 600px; height: 600px;
		background: #E50914;
		top: -200px; left: -100px;
	}

	.blob-2 {
		width: 500px; height: 500px;
		background: #312E81;
		bottom: -150px; right: -100px;
	}

	.blob-3 {
		width: 400px; height: 400px;
		background: #0EA5E9;
		top: 40%; left: 50%;
		transform: translate(-50%, -50%);
		opacity: 0.08;
	}

	/* ── Layout ── */
	main {
		position: relative;
		z-index: 1;
		max-width: 1800px;
		margin: 0 auto;
		padding: 2.5rem 2.5rem;
	}

	/* ── Header ── */
	header {
		display: grid;
		grid-template-columns: 1fr auto 1fr;
		align-items: center;
		margin-bottom: 3rem;
	}

	.logo {
		grid-column: 2;
		justify-self: center;
		margin: 0;
		line-height: 0;
	}

	.logo-img {
		height: clamp(7rem, 18vw, 16rem);
		width: auto;
		object-fit: contain;
		filter: drop-shadow(0 0 40px rgba(229, 9, 20, 0.5));
	}

	.header-right {
		grid-column: 3;
		justify-self: end;
		display: flex;
		flex-direction: column;
		align-items: flex-end;
		gap: 0.5rem;
	}

	.lang-btn {
		display: flex;
		align-items: center;
		gap: 0.3rem;
	}

	.lang-btn svg {
		width: 10px;
		height: 10px;
		flex-shrink: 0;
	}

	.locale-section-label {
		font-size: 0.7rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--muted);
		margin: 1rem 0 0.5rem;
	}

	.locale-section-label:first-of-type {
		margin-top: 0.25rem;
	}

	.locale-section-desc {
		font-size: 0.75rem;
		color: var(--muted);
		margin: -0.25rem 0 0.5rem;
		line-height: 1.4;
	}

	.locale-grid {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
	}

	.locale-option,
	.locale-country {
		background: rgba(255, 255, 255, 0.05);
		border: 1px solid rgba(255, 255, 255, 0.08);
		color: var(--muted);
		font-family: inherit;
		font-size: 0.8rem;
		font-weight: 500;
		padding: 0.4rem 0.75rem;
		border-radius: 8px;
		cursor: pointer;
		transition: background 120ms ease, color 120ms ease, border-color 120ms ease;
		white-space: nowrap;
	}

	.locale-option:hover,
	.locale-country:hover {
		background: rgba(255, 255, 255, 0.1);
		color: var(--text);
		border-color: rgba(255, 255, 255, 0.15);
	}

	.locale-option.is-active,
	.locale-country.is-active {
		color: var(--text);
		background: rgba(229, 9, 20, 0.18);
		border-color: rgba(229, 9, 20, 0.4);
	}

	@media (max-width: 768px) {
		header {
			grid-template-columns: 1fr 1fr;
			grid-template-rows: auto auto;
			row-gap: 1.25rem;
		}

		.logo {
			grid-column: 1 / -1;
			grid-row: 1;
		}

		.header-actions {
			grid-column: 1;
			grid-row: 2;
			justify-self: start;
		}

		header .header-right {
			grid-column: 2;
			grid-row: 2;
			justify-self: end;
			align-items: flex-end;
		}
	}

	@media (max-width: 480px) {
		.header-actions {
			gap: 0.35rem;
		}
	}

	/* ── Drag & drop ── */
	.drag-handle {
		display: inline-flex;
		align-items: center;
		padding: 2px 4px;
		margin-right: 0.5rem;
		border-radius: 4px;
		color: #334155;
		cursor: grab;
		transition: color 150ms ease;
		vertical-align: middle;
		touch-action: none;
	}

	.drag-handle:hover { color: #64748b; }
	.drag-handle:active { cursor: grabbing; }

	.drag-handle svg {
		width: 14px;
		height: 14px;
		display: block;
	}

	.category.is-dragging {
		opacity: 0.35;
	}

	/* Ghost element during touch drag */
	:global(.touch-ghost) {
		position: fixed;
		z-index: 999;
		pointer-events: none;
		opacity: 0.85;
		box-shadow: 0 20px 60px rgba(0,0,0,0.6);
		border-radius: 12px;
		background: #0A0A0F;
		overflow: hidden;
	}

	/* ── URL Launcher ── */
	.launcher-wrap {
		margin-bottom: 2.5rem;
	}

	/* ── Categories ── */
	.category {
		margin-bottom: 2.5rem;
	}

	.category-title {
		font-size: 0.75rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: #64748b;
		margin-bottom: 1rem;
		padding-left: 0.25rem;
		border-left: 3px solid #E50914;
		padding-left: 0.75rem;
	}

	/* ── Grid ── */
	.grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
		gap: 1.25rem;
	}

	/* Large screens (Tesla ~1920px) */
	@media (min-width: 1400px) {
		.grid {
			grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
			gap: 1.5rem;
		}
	}

	/* Tablet / landscape */
	@media (max-width: 768px) {
		.grid {
			grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
			gap: 1rem;
		}
	}

	/* Small mobile */
	@media (max-width: 480px) {
		.grid {
			grid-template-columns: repeat(2, 1fr);
			gap: 0.75rem;
		}
	}

	/* ── Card ── */
	.card {
		--mouse-x: 50%;
		--mouse-y: 50%;
		--app-color: #fff;

		position: relative;
		border-radius: 20px;
		background: var(--surface);
		border: 1px solid var(--border);
		backdrop-filter: blur(16px);
		-webkit-backdrop-filter: blur(16px);
		overflow: hidden;
		text-decoration: none;
		cursor: pointer;
		transition: transform 200ms ease, box-shadow 200ms ease, border-color 200ms ease;
		aspect-ratio: 1;
		/* Minimum tap target size */
		min-height: 160px;
	}

	.card:hover .card-inner { opacity: 1; }

	.card:hover {
		transform: scale(1.04) translateY(-3px);
		border-color: color-mix(in srgb, var(--app-color) 50%, transparent);
		box-shadow:
			0 0 0 1px color-mix(in srgb, var(--app-color) 20%, transparent),
			0 24px 48px -12px color-mix(in srgb, var(--app-color) 35%, transparent),
			0 0 100px -20px color-mix(in srgb, var(--app-color) 20%, transparent);
	}

	.card:active,
	.card.touching {
		transform: scale(0.96);
	}

	.card.touching .spotlight {
		opacity: 1;
	}

	.card.touching .border-glow {
		opacity: 1;
	}

	/* Spotlight radial gradient follows cursor */
	.spotlight {
		position: absolute;
		inset: 0;
		opacity: 0;
		transition: opacity 300ms ease;
		background: radial-gradient(
			circle at var(--mouse-x) var(--mouse-y),
			color-mix(in srgb, var(--app-color) 15%, transparent) 0%,
			transparent 60%
		);
		pointer-events: none;
		border-radius: inherit;
	}

	.card:hover .spotlight {
		opacity: 1;
	}

	/* Animated border glow */
	.border-glow {
		position: absolute;
		inset: -1px;
		border-radius: inherit;
		background: radial-gradient(
			circle at var(--mouse-x) var(--mouse-y),
			color-mix(in srgb, var(--app-color) 40%, transparent),
			transparent 60%
		);
		opacity: 0;
		transition: opacity 300ms ease;
		pointer-events: none;
		z-index: -1;
	}

	.card:hover .border-glow {
		opacity: 1;
	}

	/* Card content */
	.card-inner {
		position: relative;
		z-index: 1;
		display: flex;
		flex-direction: column;
		align-items: center;
		opacity: 0.82;
		transition: opacity 200ms ease;
		justify-content: center;
		gap: 1rem;
		height: 100%;
		padding: 1.5rem;
	}

	.icon-wrap {
		display: flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
	}

	.icon-wrap img {
		width: 80px;
		height: 80px;
		object-fit: contain;
		transition: transform 200ms ease;
	}

	.card:hover .icon-wrap img {
		transform: scale(1.08);
	}

	.icon-fallback {
		display: none;
		align-items: center;
		justify-content: center;
		width: 80px;
		height: 80px;
		font-size: 3rem;
		font-weight: 700;
	}

	.app-name {
		font-size: 1rem;
		font-weight: 600;
		color: rgba(248, 250, 252, 0.9);
		text-align: center;
		line-height: 1.3;
		letter-spacing: 0.02em;
	}

	@media (min-width: 1400px) {
		.icon-wrap img { width: 100px; height: 100px; }
		.icon-fallback { width: 100px; height: 100px; font-size: 3.5rem; }
		.app-name { font-size: 1.1rem; }
		.card-inner { gap: 1.25rem; padding: 2rem; }
	}

	@media (max-width: 480px) {
		.icon-wrap img { width: 60px; height: 60px; }
		.icon-fallback { width: 60px; height: 60px; font-size: 2.25rem; }
		.app-name { font-size: 0.875rem; }
	}

	/* ── Footer ── */
	footer {
		margin-top: 3rem;
		text-align: center;
		font-size: 0.875rem;
		color: rgba(248, 250, 252, 0.55);
		letter-spacing: 0.02em;
	}

	.footer-inner {
		display: flex;
		align-items: center;
		justify-content: center;
		flex-wrap: wrap;
		gap: 0.5rem 0.75rem;
	}

	.footer-sep {
		opacity: 0.3;
	}

	.footer-link {
		color: rgba(248, 250, 252, 0.55);
		text-decoration: none;
		transition: color 150ms ease;
	}

	.footer-link:hover {
		color: var(--text);
	}

	.footer-github {
		display: flex;
		align-items: center;
		color: rgba(248, 250, 252, 0.55);
		transition: color 150ms ease;
	}

	.footer-github:hover {
		color: var(--text);
	}

	.footer-github svg {
		width: 16px;
		height: 16px;
	}

	/* ── FAB ── */
	.fab-wrap {
		position: fixed;
		bottom: 2rem;
		right: 2rem;
		z-index: 40;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.6rem;
	}

	@keyframes fab-bounce {
		0%, 100%   { transform: translateY(0); }
		10%        { transform: translateY(-10px); }
		20%        { transform: translateY(-2px); }
		30%        { transform: translateY(-6px); }
		40%        { transform: translateY(0); }
	}

	.fab-tooltip {
		position: relative;
		background: rgba(255, 255, 255, 0.07);
		border: 1px solid rgba(255, 255, 255, 0.12);
		backdrop-filter: blur(16px);
		-webkit-backdrop-filter: blur(16px);
		color: var(--text);
		font-size: 0.8rem;
		font-weight: 600;
		letter-spacing: 0.03em;
		white-space: nowrap;
		padding: 0.5rem 1rem;
		border-radius: 10px;
		box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4);
		animation: fab-bounce 3.5s ease-in-out infinite;
	}

	.fab-tooltip-arrow {
		position: absolute;
		bottom: -8px;
		left: 50%;
		transform: translateX(-50%);
		width: 12px;
		height: 8px;
		display: block;
	}

	@keyframes fab-ping {
		75%, 100% { transform: scale(1.8); opacity: 0; }
	}

	.fab-ping {
		position: absolute;
		inset: 0;
		border-radius: 50%;
		background: rgba(229, 9, 20, 0.4);
		animation: fab-ping 1.8s cubic-bezier(0, 0, 0.2, 1) infinite;
		pointer-events: none;
	}

	.fab {
		position: relative;
		width: 72px;
		height: 72px;
		border-radius: 50%;
		background: #E50914;
		border: none;
		color: #fff;
		cursor: pointer;
		display: flex;
		align-items: center;
		justify-content: center;
		box-shadow: 0 8px 28px rgba(229, 9, 20, 0.45);
		transition: transform 150ms ease, box-shadow 150ms ease, background 150ms ease;
	}

	.fab:hover {
		transform: scale(1.08);
		background: #f0141e;
		box-shadow: 0 14px 36px rgba(229, 9, 20, 0.6);
	}

	.fab:active { transform: scale(0.95); }

	.fab svg { width: 30px; height: 30px; }

	/* ── Card delete button ── */
	.card-delete {
		position: absolute;
		top: 0.5rem;
		right: 0.5rem;
		z-index: 2;
		width: 28px;
		height: 28px;
		border-radius: 50%;
		background: rgba(0, 0, 0, 0.6);
		border: 1px solid rgba(255, 255, 255, 0.15);
		color: rgba(255, 255, 255, 0.6);
		cursor: pointer;
		display: flex;
		align-items: center;
		justify-content: center;
		opacity: 0;
		transition: opacity 150ms ease, background 150ms ease, color 150ms ease;
	}

	.card:hover .card-delete,
	.card.touching .card-delete { opacity: 1; }

	.card-delete:hover {
		background: rgba(229, 9, 20, 0.8);
		color: #fff;
		border-color: transparent;
	}

	.card-delete svg { width: 12px; height: 12px; }

	/* ── Add App Form ── */
