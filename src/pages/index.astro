							<span class="form-label">Battery</span>
							<div class="charger-range-values">
								<span class="charger-range-val charger-range-val--current">
									<span id="ch-current-pct">20%</span>
									<span class="charger-range-kwh" id="ch-current-kwh">15.0 kWh</span>
								</span>
								<span class="charger-range-arrow">→</span>
