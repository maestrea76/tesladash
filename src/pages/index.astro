			function getLangCode(full: string): string {
				const code = full.split('-')[0].toLowerCase();
				return T[code] ? code : 'en';
			}

			function applyTranslations(lang: string) {
				const t = T[lang] || T['en'];
				// data-i18n: textContent
				document.querySelectorAll<HTMLElement>('[data-i18n]').forEach(el => {
					const key = el.dataset.i18n!;
					if (t[key]) el.textContent = t[key];
				});
				// data-i18n-html: innerHTML
				document.querySelectorAll<HTMLElement>('[data-i18n-html]').forEach(el => {
					const key = el.dataset.i18nHtml!;
					if (t[key]) el.innerHTML = t[key];
				});
				// update picker button label
				const LANG_LABELS: Record<string, string> = {
					en:'🇬🇧 EN', no:'🇳🇴 NO', de:'🇩🇪 DE', sv:'🇸🇪 SV',
					nl:'🇳🇱 NL', fr:'🇫🇷 FR', da:'🇩🇰 DA', fi:'🇫🇮 FI',
					it:'🇮🇹 IT', es:'🇪🇸 ES', pt:'🇵🇹 PT', pl:'🇵🇱 PL', zh:'🇨🇳 ZH',
				};
				const cur = document.getElementById('lang-current');
				if (cur) cur.textContent = LANG_LABELS[lang] ?? LANG_LABELS['en'];
				// mark active option
				document.querySelectorAll<HTMLElement>('.locale-option').forEach(btn => {
					btn.classList.toggle('is-active', btn.dataset.lang === lang);
				});
				// dispatch event for Svelte components
				window.dispatchEvent(new CustomEvent('tesflix:langchange', { detail: { lang } }));
			}

			// Init
			const savedLang = localStorage.getItem('tesflix-lang');
			const initialLang = getLangCode(savedLang || navigator.language);
			applyTranslations(initialLang);

			// Locale modal button
			document.getElementById('lang-btn')?.addEventListener('click', () => openModal('modal-locale'));

			// ── Modals ──
			function openModal(id: string) {
				const el = document.getElementById(id);
				if (!el) return;
				el.classList.add('is-open');
				el.removeAttribute('aria-hidden');
				el.removeAttribute('inert');
			}

			function closeModal(id: string) {
				const el = document.getElementById(id);
				if (!el) return;
				el.classList.remove('is-open');
				el.setAttribute('aria-hidden', 'true');
				el.setAttribute('inert', '');
			}

			document.getElementById('btn-about')?.addEventListener('click', () => openModal('modal-about'));
			document.getElementById('btn-faq')?.addEventListener('click', () => openModal('modal-faq'));
			document.getElementById('btn-selfhost')?.addEventListener('click', () => openModal('modal-selfhost'));

			// ── Locale modal: language options ──
			document.querySelectorAll<HTMLElement>('.locale-option').forEach(btn => {
				btn.addEventListener('click', () => {
					const lang = btn.dataset.lang!;
					localStorage.setItem('tesflix-lang', lang);
					applyTranslations(lang);
				});
			});

			// ── Locale modal: country options ──
			function applyCountryActive(country: string) {
				document.querySelectorAll<HTMLElement>('.locale-country').forEach(b => {
					b.classList.toggle('is-active', b.dataset.country === country);
				});
			}

			document.querySelectorAll<HTMLElement>('.locale-country').forEach(btn => {
				btn.addEventListener('click', () => {
					const country = btn.dataset.country!;
					localStorage.setItem('tesflix-region', country);
					applyRegionFilter(country);
					applyCountryActive(country);
				});
			});
			document.getElementById('btn-support')?.addEventListener('click', () => openModal('modal-support'));

			// ── Support modal two-view logic ──
			const SUPPORT_PLATFORMS: Record<string, { name: string; url: string }> = {
				github: { name: 'GitHub Sponsors', url: 'https://github.com/sponsors/crstian19' },
				bmc:    { name: 'Buy Me a Coffee',  url: 'https://buymeacoffee.com/crstian' },
				paypal: { name: 'PayPal',            url: 'https://www.paypal.com/cgi-bin/webscr?cmd=_s-xclick&hosted_button_id=MUW2XFMQB2782' },
			};

			function showSupportDetail(platform: string) {
				const p = SUPPORT_PLATFORMS[platform];
				if (!p) return;
				const qr = 'https://api.qrserver.com/v1/create-qr-code/?size=200x200&color=000000&bgcolor=FFFFFF&data=' + encodeURIComponent(p.url);
				(document.getElementById('support-qr-img') as HTMLImageElement).src = qr;
				(document.getElementById('support-open-btn') as HTMLAnchorElement).href = p.url;
				document.getElementById('support-platform-label')!.textContent = p.name;
				document.getElementById('support-view-list')!.classList.add('support-view--hidden');
				document.getElementById('support-view-detail')!.classList.remove('support-view--hidden');
			}

			function showSupportList() {
				document.getElementById('support-view-list')!.classList.remove('support-view--hidden');
				document.getElementById('support-view-detail')!.classList.add('support-view--hidden');
			}

			document.querySelectorAll<HTMLElement>('.support-card').forEach(btn => {
				btn.addEventListener('click', () => showSupportDetail(btn.dataset.platform!));
			});
			document.getElementById('support-back')?.addEventListener('click', showSupportList);

			// Reset to list when modal closes
			document.querySelector('[data-close="modal-support"]')?.addEventListener('click', () => {
				setTimeout(showSupportList, 300);
			});

			document.querySelectorAll<HTMLElement>('[data-close]').forEach(btn => {
				btn.addEventListener('click', () => closeModal(btn.dataset.close!));
			});

			document.querySelectorAll<HTMLElement>('.modal-overlay').forEach(overlay => {
				overlay.addEventListener('click', (e) => {
					if (e.target === overlay) closeModal(overlay.id);
				});
			});

			document.addEventListener('keydown', (e: KeyboardEvent) => {
				if (e.key === 'Escape') {
					document.querySelectorAll<HTMLElement>('.modal-overlay.is-open').forEach(el => closeModal(el.id));
				}
			});

			// ── Cards ──
			function applySpotlight(card: HTMLElement, clientX: number, clientY: number) {
				const rect = card.getBoundingClientRect();
				card.style.setProperty('--mouse-x', `${((clientX - rect.left) / rect.width) * 100}%`);
				card.style.setProperty('--mouse-y', `${((clientY - rect.top) / rect.height) * 100}%`);
			}

			const isTouchDevice = window.matchMedia('(pointer: coarse)').matches;

			function attachSpotlight(card: HTMLElement) {
				if (isTouchDevice) return;
				card.addEventListener('mousemove', (e: MouseEvent) => applySpotlight(card, e.clientX, e.clientY));
			}

			document.querySelectorAll<HTMLElement>('.card').forEach(attachSpotlight);

			const STORAGE_KEY = 'tesflix-category-order';
			const container = document.getElementById('categories') as HTMLElement;

			function getSections() {
				return [...container.querySelectorAll<HTMLElement>('.category')];
			}

			function saveOrder() {
				const order = getSections().map(s => s.dataset.category!);
				localStorage.setItem(STORAGE_KEY, JSON.stringify(order));
			}

			function restoreOrder() {
				const saved = localStorage.getItem(STORAGE_KEY);
				if (!saved) return;
				const order: string[] = JSON.parse(saved);
				order.forEach(name => {
					const el = container.querySelector<HTMLElement>(`[data-category="${name}"]`);
					if (el) container.appendChild(el);
				});
			}

			function insertAdjacent(dragged: HTMLElement, target: HTMLElement, clientY: number) {
				if (dragged === target) return;
				const rect = target.getBoundingClientRect();
				if (clientY < rect.top + rect.height / 2) {
					container.insertBefore(dragged, target);
				} else {
					container.insertBefore(dragged, target.nextSibling);
				}
			}

			let dragging: HTMLElement | null = null;
			let touchDragging: HTMLElement | null = null;
			let ghost: HTMLElement | null = null;
			let touchOffsetY = 0;

			function initSectionDrag(section: HTMLElement) {
				const handle = section.querySelector<HTMLElement>('.drag-handle');
				if (!handle) return;
				handle.style.cursor = 'grab';

				section.addEventListener('dragstart', (e: DragEvent) => {
					dragging = section;
					section.classList.add('is-dragging');
					e.dataTransfer!.effectAllowed = 'move';
				});
				section.addEventListener('dragend', () => {
					dragging = null;
					section.classList.remove('is-dragging');
					document.querySelectorAll('.drop-indicator').forEach(el => el.remove());
					saveOrder();
				});
				section.addEventListener('dragover', (e: DragEvent) => {
					e.preventDefault();
					if (dragging) insertAdjacent(dragging, section, e.clientY);
				});
				handle.addEventListener('mousedown', () => { section.draggable = true; });
				document.addEventListener('mouseup', () => { section.draggable = false; });
				handle.addEventListener('touchstart', (e: TouchEvent) => {
					const touch = e.touches[0];
					touchDragging = section;
					touchOffsetY = touch.clientY - section.getBoundingClientRect().top;
					ghost = section.cloneNode(true) as HTMLElement;
					ghost.classList.add('touch-ghost');
					ghost.style.width = section.offsetWidth + 'px';
					ghost.style.top = (touch.clientY - touchOffsetY) + 'px';
					ghost.style.left = section.getBoundingClientRect().left + 'px';
					document.body.appendChild(ghost);
					section.classList.add('is-dragging');
					e.preventDefault();
				}, { passive: false });
			}

			getSections().forEach(initSectionDrag);

			document.addEventListener('touchmove', (e: TouchEvent) => {
				if (!touchDragging || !ghost) return;
				const touch = e.touches[0];

				ghost.style.top = (touch.clientY - touchOffsetY) + 'px';

				ghost.style.display = 'none';
				const el = document.elementFromPoint(touch.clientX, touch.clientY);
				ghost.style.display = '';
				const target = el?.closest<HTMLElement>('.category');
				if (target && target !== touchDragging) {
					insertAdjacent(touchDragging, target, touch.clientY);
				}
			}, { passive: true });

			document.addEventListener('touchend', () => {
				if (!touchDragging) return;
				touchDragging.classList.remove('is-dragging');
				ghost?.remove();
				ghost = null;
				touchDragging = null;
				saveOrder();
			});

			restoreOrder();

