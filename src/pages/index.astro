<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>Tesflix</title>
		<meta name="description" content="Tesflix — a community-made dashboard for Tesla's in-car browser. Stream music, videos, and more directly from your Tesla." />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<Font cssVariable="--font-geist" preload />
	</head>

	<body>
