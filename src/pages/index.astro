<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>Tesdash</title>
		<meta name="description" content="Tesdash — a community-made dashboard for Tesla's in-car browser. Stream music, videos, and more directly from your Tesla." />
		<link rel="icon" href="/favicon.ico" sizes="any" />
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
		<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
		<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
		<link rel="manifest" href="/site.webmanifest" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Noto+Color+Emoji&display=swap" />
		<Font cssVariable="--font-geist" preload />
	</head>

	<body>
		<div class="ambient" aria-hidden="true">
			<div class="blob blob-1"></div>
			<div class="blob blob-2"></div>
			<div class="blob blob-3"></div>
		</div>

		<main>
			<header>
				<div class="header-actions">
					<div class="header-actions-row">
						<button class="header-btn" id="btn-about" data-i18n="btn.about">About</button>
						<button class="header-btn" id="btn-faq">FAQ</button>
						<button class="header-btn" id="btn-selfhost" data-i18n="btn.selfhost">Self-Host</button>

					</div>
					<button class="header-btn header-btn--support" id="btn-support">
						<span class="support-btn-heart" aria-hidden="true">
							<span class="support-btn-ping"></span>
							❤️
						</span>
						<span data-i18n="btn.support">Support this project</span>
					</button>
					<button class="header-btn header-btn--charger" id="btn-charger">
						<svg class="charger-bolt" viewBox="0 0 24 24" aria-hidden="true" width="16" height="16">
							<path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" fill="#facc15" stroke="#facc15" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
							<path class="bolt-trace" d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" pathLength="100"/>
						</svg>
						<span data-i18n="btn.charger">Charge Calc</span>
					</button>
				</div>
				<h1 class="logo">
					<picture>
						<source srcset="/logos/tesdash.webp" type="image/webp" />
						<img src="/logos/nobg-tesdash.png" alt="Tesdash" class="logo-img" fetchpriority="high" />
					</picture>
				</h1>
				<div class="header-right">
					<button class="header-btn lang-btn" id="lang-btn" aria-label="Language & Region">
						<span id="lang-current">🇬🇧 EN</span>
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
					</button>
					<Clock client:load />
				</div>
			</header>

			<!-- About Modal -->
			<div class="modal-overlay" id="modal-about" aria-hidden="true" inert>
				<div class="modal-box" role="dialog" aria-modal="true" aria-labelledby="about-title">
					<button class="modal-close" data-close="modal-about" aria-label="Close">&times;</button>
					<h2 id="about-title" class="modal-title" data-i18n="about.title">About Tesdash</h2>
					<p class="modal-text" data-i18n="about.p1">
						Tesdash is a self-hosted, static dashboard designed to launch streaming services,
						music platforms, sports channels, personal media, gaming, and homelab tools —
						all from your Tesla's in-vehicle browser.
					</p>
					<p class="modal-text" data-i18n="about.p2">
						It runs entirely in your browser with no server required after deployment.
						Categories can be reordered to match your preferences, and a built-in URL launcher
						lets you open any website in fullscreen.
					</p>
					<p class="modal-text about-author">
						<span class="about-author-label" data-i18n="about.author-label">Author</span>
						<a href="https://crstian.me" target="_blank" rel="noopener noreferrer" class="about-author-link">Crstian</a>
					</p>

					<div class="stack-wrap">
						<span class="stack-label" data-i18n="about.built-with">Built with</span>
						<div class="stack-chips">
							<a href="https://astro.build" target="_blank" rel="noopener noreferrer" class="stack-chip">
