						{cat.name}
					</h2>
					<div class="grid">
						{cat.apps.map((app) => (
							<a
								href={app.href}
								target="_blank"
								rel="noopener noreferrer"
								class="card"
								style={`--app-color: ${app.color};`}
								data-regions={app.regions?.length ? app.regions.join(",") : undefined}
							>
								<span class="spotlight" aria-hidden="true"></span>
								<span class="border-glow" aria-hidden="true"></span>
								<div class="card-inner">
									<div class="icon-wrap">
										<img
											src={app.logo}
											alt={`${app.name} logo`}
											width="80"
											height="80"
											onerror="this.style.display='none';this.nextElementSibling.style.display='flex';"
										/>
										<span class="icon-fallback" style={`color: ${app.color};`}>
											{app.name[0]}
										</span>
									</div>
									<p class="app-name">{app.name}</p>
								</div>
							</a>
						))}
					</div>
				</section>
			))}
