			function getLangCode(full: string): string {
				const code = full.split('-')[0].toLowerCase();
				return T[code] ? code : 'en';
			}

			function applyTranslations(lang: string) {
				const t = T[lang] || T['en'];
				// data-i18n: textContent
				document.querySelectorAll<HTMLElement>('[data-i18n]').forEach(el => {
					const key = el.dataset.i18n!;
					if (t[key]) el.textContent = t[key];
				});
				// data-i18n-html: innerHTML
				document.querySelectorAll<HTMLElement>('[data-i18n-html]').forEach(el => {
					const key = el.dataset.i18nHtml!;
					if (t[key]) el.innerHTML = t[key];
				});
				// update picker button label
				const LANG_LABELS: Record<string, string> = {
					en:'🇬🇧 EN', no:'🇳🇴 NO', de:'🇩🇪 DE', sv:'🇸🇪 SV',
					nl:'🇳🇱 NL', fr:'🇫🇷 FR', da:'🇩🇰 DA', fi:'🇫🇮 FI',
					it:'🇮🇹 IT', es:'🇪🇸 ES', pt:'🇵🇹 PT', pl:'🇵🇱 PL', zh:'🇨🇳 ZH',
				};
				const cur = document.getElementById('lang-current');
				if (cur) cur.textContent = LANG_LABELS[lang] ?? LANG_LABELS['en'];
				// mark active option
				document.querySelectorAll<HTMLElement>('.locale-option').forEach(btn => {
					btn.classList.toggle('is-active', btn.dataset.lang === lang);
				});
				// dispatch event for Svelte components
				window.dispatchEvent(new CustomEvent('tesdash:langchange', { detail: { lang } }));
			}

			// Init
			const savedLang = localStorage.getItem('tesdash-lang');
			const initialLang = getLangCode(savedLang || navigator.language);
			applyTranslations(initialLang);

			// Locale modal button
			document.getElementById('lang-btn')?.addEventListener('click', () => openModal('modal-locale'));

			// ── Modals ──
			function openModal(id: string) {
				const el = document.getElementById(id);
				if (!el) return;
				el.classList.add('is-open');
				el.removeAttribute('aria-hidden');
				el.removeAttribute('inert');
			}

			function closeModal(id: string) {
				const el = document.getElementById(id);
				if (!el) return;
				el.classList.remove('is-open');
				el.setAttribute('aria-hidden', 'true');
				el.setAttribute('inert', '');
			}

			document.getElementById('btn-about')?.addEventListener('click', () => openModal('modal-about'));
			document.getElementById('btn-faq')?.addEventListener('click', () => openModal('modal-faq'));
			document.getElementById('btn-selfhost')?.addEventListener('click', () => openModal('modal-selfhost'));
			document.getElementById('btn-charger')?.addEventListener('click', () => openModal('modal-charger'));

			// ── EV Charging Calculator ──
			const chModel    = document.getElementById('ch-model') as HTMLSelectElement;
			const chCapacity = document.getElementById('ch-capacity') as HTMLInputElement;
			const chCurrent  = document.getElementById('ch-current') as HTMLInputElement;
			const chTarget   = document.getElementById('ch-target') as HTMLInputElement;
			const chFill     = document.getElementById('ch-range-fill') as HTMLElement;

			chModel?.addEventListener('change', () => {
				if (chModel.value) {
					chCapacity.value = chModel.value;
					syncTimeFromSliders();
					calcCharger();
				}
			});

			chCapacity?.addEventListener('input', () => {
				chModel.value = '';
				syncTimeFromSliders();
				calcCharger();
			});

			function updateDualRange() {
				const lo = parseFloat(chCurrent.value);
				const hi = parseFloat(chTarget.value);
				chFill.style.left  = lo + '%';
				chFill.style.width = (hi - lo) + '%';
				// z-index: when current reaches right edge, it needs to be on top to drag back left
				const atMax = lo >= 99;
				chCurrent.style.zIndex = atMax ? '4' : '2';
				chTarget.style.zIndex  = atMax ? '2' : '4';
			}

			function calcCharger() {
				const capacity = parseFloat(chCapacity.value) || 0;
				const power    = parseFloat((document.getElementById('ch-power') as HTMLInputElement).value) || 0;
				const price    = parseFloat((document.getElementById('ch-price') as HTMLInputElement).value) || 0;
				const time     = parseFloat((document.getElementById('ch-time') as HTMLInputElement).value) || 0;
				const current  = parseFloat(chCurrent.value) || 0;
				const target   = parseFloat(chTarget.value) || 100;

				(document.getElementById('ch-current-pct') as HTMLElement).textContent = current + '%';
				(document.getElementById('ch-target-pct') as HTMLElement).textContent  = target + '%';
				if (capacity > 0) {
					(document.getElementById('ch-current-kwh') as HTMLElement).textContent = (capacity * current / 100).toFixed(1) + ' kWh';
					(document.getElementById('ch-target-kwh') as HTMLElement).textContent  = (capacity * target  / 100).toFixed(1) + ' kWh';
				}
				updateDualRange();

				if (capacity <= 0 || power <= 0) return;

				const energyNeeded = Math.max(0, capacity * (target - current) / 100);
				const energyAdded  = Math.min(power * time, energyNeeded);
				const finalPct     = Math.min(target, current + (energyAdded / capacity) * 100);
				const costSession  = energyAdded * price;
				const timeToTarget = energyNeeded / power;

				const fmt     = (v: number, d = 1) => v.toFixed(d);
				const fmtTime = (h: number) => {
					if (h <= 0) return '0m';
					const hh = Math.floor(h);
					const mm = Math.round((h - hh) * 60);
					if (hh > 0 && mm > 0) return `${hh}h ${mm}m`;
					if (hh > 0) return `${hh}h`;
					return `${mm}m`;
				};

				(document.getElementById('ch-result-energy') as HTMLElement).textContent     = fmt(energyAdded) + ' kWh';
				(document.getElementById('ch-result-final') as HTMLElement).textContent      = fmt(finalPct, 0) + '%';
				(document.getElementById('ch-result-cost') as HTMLElement).textContent       = fmt(costSession, 2) + ' €';
				(document.getElementById('ch-result-timetofull') as HTMLElement).textContent = fmtTime(timeToTarget);
			}

			function syncTimeFromSliders() {
				const capacity = parseFloat(chCapacity.value) || 0;
				const power    = parseFloat((document.getElementById('ch-power') as HTMLInputElement).value) || 0;
				const current  = parseFloat(chCurrent.value) || 0;
				const target   = parseFloat(chTarget.value) || 0;
				if (capacity > 0 && power > 0 && target >= current) {
					const t = (capacity * (target - current) / 100) / power;
					(document.getElementById('ch-time') as HTMLInputElement).value = t.toFixed(2);
				}
			}

			chCurrent?.addEventListener('input', () => {
				if (parseFloat(chCurrent.value) > parseFloat(chTarget.value))
					chCurrent.value = chTarget.value;
				syncTimeFromSliders();
				calcCharger();
			});

			chTarget?.addEventListener('input', () => {
				if (parseFloat(chTarget.value) < parseFloat(chCurrent.value))
					chTarget.value = chCurrent.value;
				syncTimeFromSliders();
				calcCharger();
			});

			// power/capacity also recalc time since it affects how long to reach target
			['ch-power'].forEach(id => {
				document.getElementById(id)?.addEventListener('input', () => {
					syncTimeFromSliders();
					calcCharger();
				});
			});

			document.getElementById('ch-price')?.addEventListener('input', calcCharger);
			document.getElementById('ch-time')?.addEventListener('input', calcCharger);
			calcCharger();

			// ── Locale modal: language options ──
			document.querySelectorAll<HTMLElement>('.locale-option').forEach(btn => {
				btn.addEventListener('click', () => {
					const lang = btn.dataset.lang!;
					localStorage.setItem('tesdash-lang', lang);
					applyTranslations(lang);
				});
			});

			// ── Locale modal: country options ──
			function applyCountryActive(country: string) {
				document.querySelectorAll<HTMLElement>('.locale-country').forEach(b => {
					b.classList.toggle('is-active', b.dataset.country === country);
				});
			}

			document.querySelectorAll<HTMLElement>('.locale-country').forEach(btn => {
				btn.addEventListener('click', () => {
					const country = btn.dataset.country!;
					localStorage.setItem('tesdash-region', country);
					applyRegionFilter(country);
					applyCountryActive(country);
				});
			});
			document.getElementById('btn-support')?.addEventListener('click', () => openModal('modal-support'));

			// ── Support modal two-view logic ──
			const SUPPORT_PLATFORMS: Record<string, { name: string; url: string }> = {
				github: { name: 'GitHub Sponsors', url: 'https://github.com/sponsors/crstian19' },
				bmc:    { name: 'Buy Me a Coffee',  url: 'https://buymeacoffee.com/crstian' },
				paypal: { name: 'PayPal',            url: 'https://www.paypal.com/cgi-bin/webscr?cmd=_s-xclick&hosted_button_id=MUW2XFMQB2782' },
			};

			function showSupportDetail(platform: string) {
				const p = SUPPORT_PLATFORMS[platform];
				if (!p) return;
				const qr = 'https://api.qrserver.com/v1/create-qr-code/?size=200x200&color=000000&bgcolor=FFFFFF&data=' + encodeURIComponent(p.url);
				(document.getElementById('support-qr-img') as HTMLImageElement).src = qr;
				(document.getElementById('support-open-btn') as HTMLAnchorElement).href = p.url;
				document.getElementById('support-platform-label')!.textContent = p.name;
				document.getElementById('support-view-list')!.classList.add('support-view--hidden');
				document.getElementById('support-view-detail')!.classList.remove('support-view--hidden');
			}

			function showSupportList() {
				document.getElementById('support-view-list')!.classList.remove('support-view--hidden');
				document.getElementById('support-view-detail')!.classList.add('support-view--hidden');
			}

			document.querySelectorAll<HTMLElement>('.support-card').forEach(btn => {
				btn.addEventListener('click', () => showSupportDetail(btn.dataset.platform!));
			});
			document.getElementById('support-back')?.addEventListener('click', showSupportList);

			// Reset to list when modal closes
			document.querySelector('[data-close="modal-support"]')?.addEventListener('click', () => {
				setTimeout(showSupportList, 300);
			});

			document.querySelectorAll<HTMLElement>('[data-close]').forEach(btn => {
				btn.addEventListener('click', () => closeModal(btn.dataset.close!));
			});

			document.querySelectorAll<HTMLElement>('.modal-overlay').forEach(overlay => {
				overlay.addEventListener('click', (e) => {
					if (e.target === overlay) closeModal(overlay.id);
				});
			});

			document.addEventListener('keydown', (e: KeyboardEvent) => {
				if (e.key === 'Escape') {
					document.querySelectorAll<HTMLElement>('.modal-overlay.is-open').forEach(el => closeModal(el.id));
				}
			});

			// ── Cards ──
			function applySpotlight(card: HTMLElement, clientX: number, clientY: number) {
				const rect = card.getBoundingClientRect();
				card.style.setProperty('--mouse-x', `${((clientX - rect.left) / rect.width) * 100}%`);
				card.style.setProperty('--mouse-y', `${((clientY - rect.top) / rect.height) * 100}%`);
			}

			const isTouchDevice = window.matchMedia('(pointer: coarse)').matches;

			function attachSpotlight(card: HTMLElement) {
				if (isTouchDevice) return;
				card.addEventListener('mousemove', (e: MouseEvent) => applySpotlight(card, e.clientX, e.clientY));
			}

			document.querySelectorAll<HTMLElement>('.card').forEach(attachSpotlight);

			const STORAGE_KEY = 'tesdash-category-order';
			const container = document.getElementById('categories') as HTMLElement;

			function getSections() {
				return [...container.querySelectorAll<HTMLElement>('.category')];
			}

			function saveOrder() {
				const order = getSections().map(s => s.dataset.category!);
				localStorage.setItem(STORAGE_KEY, JSON.stringify(order));
			}

			function restoreOrder() {
				const saved = localStorage.getItem(STORAGE_KEY);
				if (!saved) return;
				const order: string[] = JSON.parse(saved);
				order.forEach(name => {
					const el = container.querySelector<HTMLElement>(`[data-category="${name}"]`);
					if (el) container.appendChild(el);
				});
			}

			function insertAdjacent(dragged: HTMLElement, target: HTMLElement, clientY: number) {
				if (dragged === target) return;
				const rect = target.getBoundingClientRect();
				if (clientY < rect.top + rect.height / 2) {
					container.insertBefore(dragged, target);
				} else {
					container.insertBefore(dragged, target.nextSibling);
				}
			}

			let dragging: HTMLElement | null = null;
			let touchDragging: HTMLElement | null = null;
			let ghost: HTMLElement | null = null;
			let touchOffsetY = 0;

			function initSectionDrag(section: HTMLElement) {
				const handle = section.querySelector<HTMLElement>('.drag-handle');
				if (!handle) return;
				handle.style.cursor = 'grab';

				section.addEventListener('dragstart', (e: DragEvent) => {
					dragging = section;
					section.classList.add('is-dragging');
					e.dataTransfer!.effectAllowed = 'move';
				});
				section.addEventListener('dragend', () => {
					dragging = null;
					section.classList.remove('is-dragging');
					document.querySelectorAll('.drop-indicator').forEach(el => el.remove());
					saveOrder();
				});
				section.addEventListener('dragover', (e: DragEvent) => {
					e.preventDefault();
					if (dragging) insertAdjacent(dragging, section, e.clientY);
				});
				handle.addEventListener('mousedown', () => { section.draggable = true; });
				document.addEventListener('mouseup', () => { section.draggable = false; });
				handle.addEventListener('touchstart', (e: TouchEvent) => {
					const touch = e.touches[0];
					touchDragging = section;
					touchOffsetY = touch.clientY - section.getBoundingClientRect().top;
					ghost = section.cloneNode(true) as HTMLElement;
					ghost.classList.add('touch-ghost');
					ghost.style.width = section.offsetWidth + 'px';
					ghost.style.top = (touch.clientY - touchOffsetY) + 'px';
					ghost.style.left = section.getBoundingClientRect().left + 'px';
					document.body.appendChild(ghost);
					section.classList.add('is-dragging');
					e.preventDefault();
				}, { passive: false });
			}

			getSections().forEach(initSectionDrag);

			document.addEventListener('touchmove', (e: TouchEvent) => {
				if (!touchDragging || !ghost) return;
				const touch = e.touches[0];

				ghost.style.top = (touch.clientY - touchOffsetY) + 'px';

				ghost.style.display = 'none';
				const el = document.elementFromPoint(touch.clientX, touch.clientY);
				ghost.style.display = '';
				const target = el?.closest<HTMLElement>('.category');
				if (target && target !== touchDragging) {
					insertAdjacent(touchDragging, target, touch.clientY);
				}
			}, { passive: true });

			document.addEventListener('touchend', () => {
				if (!touchDragging) return;
				touchDragging.classList.remove('is-dragging');
				ghost?.remove();
				ghost = null;
				touchDragging = null;
				saveOrder();
			});

			restoreOrder();

			// ── Region filter (GPS timezone → country) ──
			const TZ_COUNTRY: Record<string, string> = {
				// Spain
				'Europe/Madrid': 'ES', 'Atlantic/Canary': 'ES',
				// France
				'Europe/Paris': 'FR',
				// Germany
				'Europe/Berlin': 'DE', 'Europe/Busingen': 'DE',
				// Netherlands
				'Europe/Amsterdam': 'NL',
				// Belgium
				'Europe/Brussels': 'BE',
				// UK
				'Europe/London': 'GB',
				// Italy
				'Europe/Rome': 'IT',
				// Portugal
				'Europe/Lisbon': 'PT', 'Atlantic/Azores': 'PT', 'Atlantic/Madeira': 'PT',
				// Austria
				'Europe/Vienna': 'AT',
				// Switzerland
				'Europe/Zurich': 'CH',
				// Norway
				'Europe/Oslo': 'NO',
				// Sweden
				'Europe/Stockholm': 'SE',
				// Denmark
				'Europe/Copenhagen': 'DK',
				// Finland
				'Europe/Helsinki': 'FI',
				// Poland
				'Europe/Warsaw': 'PL',
				// Czech Republic
				'Europe/Prague': 'CZ',
				// Hungary
				'Europe/Budapest': 'HU',
				// Romania
				'Europe/Bucharest': 'RO',
				// Greece
				'Europe/Athens': 'GR',
				// Ireland
				'Europe/Dublin': 'IE',
				// Luxembourg
				'Europe/Luxembourg': 'LU',
				// Slovakia
				'Europe/Bratislava': 'SK',
				// Slovenia
				'Europe/Ljubljana': 'SI',
				// Croatia
				'Europe/Zagreb': 'HR',
				// Serbia
				'Europe/Belgrade': 'RS',
				// Bulgaria
				'Europe/Sofia': 'BG',
				// USA
				'America/New_York': 'US', 'America/Chicago': 'US', 'America/Denver': 'US',
				'America/Los_Angeles': 'US', 'America/Phoenix': 'US', 'America/Anchorage': 'US',
				'Pacific/Honolulu': 'US',
				// Canada
				'America/Toronto': 'CA', 'America/Vancouver': 'CA', 'America/Edmonton': 'CA',
				'America/Winnipeg': 'CA', 'America/Halifax': 'CA',
				// Australia
				'Australia/Sydney': 'AU', 'Australia/Melbourne': 'AU', 'Australia/Brisbane': 'AU',
				'Australia/Perth': 'AU', 'Australia/Adelaide': 'AU',
				// Japan
				'Asia/Tokyo': 'JP',
				// China
				'Asia/Shanghai': 'CN', 'Asia/Urumqi': 'CN',
				// South Korea
				'Asia/Seoul': 'KR',
				// Norway (Svalbard)
				'Arctic/Longyearbyen': 'NO',
			};

			function detectCountry(): string {
				try {
					const tz = Intl.DateTimeFormat().resolvedOptions().timeZone;
					return TZ_COUNTRY[tz] ?? '';
				} catch {
					return '';
				}
			}

			function applyRegionFilter(country: string) {
				// Reset all region-filtered cards first
				document.querySelectorAll<HTMLElement>('[data-regions]').forEach(card => {
					card.style.display = '';
				});
				document.querySelectorAll<HTMLElement>('.category').forEach(section => {
					section.style.display = '';
				});

				if (!country) return; // no country = show everything

				document.querySelectorAll<HTMLElement>('[data-regions]').forEach(card => {
					const regions = card.dataset.regions;
					if (!regions) return; // no attribute = global app, always visible
					card.style.display = regions.split(',').includes(country) ? '' : 'none';
				});

				// Hide category sections that end up with no visible cards
				document.querySelectorAll<HTMLElement>('.category').forEach(section => {
					const grid = section.querySelector<HTMLElement>('.grid');
					if (!grid) return;
					const hasVisible = [...grid.querySelectorAll<HTMLElement>('.card')]
						.some(c => c.style.display !== 'none');
					section.style.display = hasVisible ? '' : 'none';
				});
			}

			const regionOverride = localStorage.getItem('tesdash-region');
			const detectedCountry = regionOverride !== null ? regionOverride : detectCountry();
			applyRegionFilter(detectedCountry);
			applyCountryActive(detectedCountry);

			// ── Custom Apps ──
			const CUSTOM_KEY = 'tesdash-custom-apps';
			const YOUTUBE_REDIRECT = 'https://www.youtube.com/redirect?q=';

			interface CustomApp {
				id: string;
				name: string;
				url: string;
				logo: string;
				color: string;
				category: string;
				fullscreen: boolean;
			}

			function loadCustomApps(): CustomApp[] {
				try { return JSON.parse(localStorage.getItem(CUSTOM_KEY) || '[]'); }
				catch { return []; }
			}

			function saveCustomApps(apps: CustomApp[]) {
				localStorage.setItem(CUSTOM_KEY, JSON.stringify(apps));
			}

			function createCustomCard(app: CustomApp): HTMLAnchorElement {
				const a = document.createElement('a');
				a.href = app.fullscreen ? `${YOUTUBE_REDIRECT}${encodeURIComponent(app.url)}` : app.url;
				a.target = '_blank';
				a.rel = 'noopener noreferrer';
				a.className = 'card';
				a.style.setProperty('--app-color', app.color);
				a.dataset.customId = app.id;

				const spotlight = document.createElement('span');
				spotlight.className = 'spotlight';
				spotlight.setAttribute('aria-hidden', 'true');

				const borderGlow = document.createElement('span');
				borderGlow.className = 'border-glow';
				borderGlow.setAttribute('aria-hidden', 'true');

				const inner = document.createElement('div');
				inner.className = 'card-inner';

				const iconWrap = document.createElement('div');
				iconWrap.className = 'icon-wrap';

				const fallback = document.createElement('span');
				fallback.className = 'icon-fallback';
				fallback.style.color = app.color;

				if (app.logo) {
					const img = document.createElement('img');
					img.src = app.logo;
					img.alt = `${app.name} logo`;
					img.width = 80;
					img.height = 80;
					img.onerror = () => { img.style.display = 'none'; fallback.style.display = 'flex'; };
					iconWrap.appendChild(img);
					fallback.style.display = 'none';
				} else {
					fallback.style.display = 'flex';
				}
				fallback.textContent = app.name[0]?.toUpperCase() ?? '?';
				iconWrap.appendChild(fallback);

				const appName = document.createElement('p');
				appName.className = 'app-name';
				appName.textContent = app.name;

				inner.appendChild(iconWrap);
				inner.appendChild(appName);

				const deleteBtn = document.createElement('button');
				deleteBtn.className = 'card-delete';
				deleteBtn.setAttribute('aria-label', `Delete ${app.name}`);
				deleteBtn.innerHTML = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M18 6 6 18M6 6l12 12"/></svg>`;
				deleteBtn.addEventListener('click', (e) => {
					e.preventDefault();
					e.stopPropagation();
					deleteCustomApp(app.id);
				});

				a.appendChild(spotlight);
				a.appendChild(borderGlow);
				a.appendChild(inner);
				a.appendChild(deleteBtn);
				attachSpotlight(a);
				return a;
			}

			function getOrCreateCategorySection(categoryName: string): HTMLElement {
				let section = container.querySelector<HTMLElement>(`[data-category="${CSS.escape(categoryName)}"]`);
				if (section) return section;

				section = document.createElement('section');
				section.className = 'category';
				section.dataset.category = categoryName;

				const title = document.createElement('h2');
				title.className = 'category-title';
				title.innerHTML = `<span class="drag-handle" aria-hidden="true"><svg viewBox="0 0 24 24" fill="currentColor"><circle cx="9" cy="5" r="1.5"/><circle cx="15" cy="5" r="1.5"/><circle cx="9" cy="12" r="1.5"/><circle cx="15" cy="12" r="1.5"/><circle cx="9" cy="19" r="1.5"/><circle cx="15" cy="19" r="1.5"/></svg></span>`;
				title.appendChild(document.createTextNode(categoryName));

				const grid = document.createElement('div');
				grid.className = 'grid';

				section.appendChild(title);
				section.appendChild(grid);
				container.appendChild(section);
				initSectionDrag(section);
				return section;
			}

			function renderCustomApps() {
				// Remove existing custom cards
				document.querySelectorAll<HTMLElement>('[data-custom-id]').forEach(el => el.remove());
				// Remove empty custom-only sections
				document.querySelectorAll<HTMLElement>('.category[data-custom-section]').forEach(el => el.remove());

				const apps = loadCustomApps();
				apps.forEach(app => {
					const section = getOrCreateCategorySection(app.category);
					if (!section.dataset.customSection) {
						// Mark if this section was created just for custom apps (no static apps)
						const isNewSection = !section.querySelector('.card:not([data-custom-id])');
						if (isNewSection) section.dataset.customSection = 'true';
					}
					section.querySelector('.grid')?.appendChild(createCustomCard(app));
				});
			}

			function deleteCustomApp(id: string) {
				const apps = loadCustomApps().filter(a => a.id !== id);
				saveCustomApps(apps);
				renderCustomApps();
			}

			renderCustomApps();

			// ── Add App Form ──
			document.getElementById('btn-add-app')?.addEventListener('click', () => {
				// Populate category select from current DOM
				const select = document.getElementById('app-category') as HTMLSelectElement;
				select.innerHTML = '';
				getSections().forEach(section => {
					const name = section.dataset.category!;
					const opt = document.createElement('option');
					opt.value = name;
					opt.textContent = name;
					select.appendChild(opt);
				});
				const newOpt = document.createElement('option');
				newOpt.value = '__new__';
				newOpt.textContent = '+ New category…';
				select.appendChild(newOpt);

				// Reset form
				(document.getElementById('add-app-form') as HTMLFormElement).reset();
				(document.getElementById('app-color') as HTMLInputElement).value = '#e50914';
				(document.getElementById('new-cat-row') as HTMLElement).style.display = 'none';
				(document.getElementById('form-error') as HTMLElement).style.display = 'none';
				const fsCheckbox = document.getElementById('app-fullscreen') as HTMLInputElement;
				fsCheckbox.checked = true;
				(document.getElementById('app-fullscreen-hint') as HTMLElement).textContent = 'Opens via YouTube redirect (fullscreen in Tesla)';
				openModal('modal-add-app');
			});

			document.getElementById('app-fullscreen')?.addEventListener('change', function(this: HTMLInputElement) {
				(document.getElementById('app-fullscreen-hint') as HTMLElement).textContent = this.checked
					? 'Opens via YouTube redirect (fullscreen in Tesla)'
					: 'Opens directly in the browser (normal tab)';
			});

			document.getElementById('app-category')?.addEventListener('change', (e) => {
				const val = (e.target as HTMLSelectElement).value;
				(document.getElementById('new-cat-row') as HTMLElement).style.display = val === '__new__' ? '' : 'none';
			});

			document.getElementById('add-app-form')?.addEventListener('submit', (e) => {
				e.preventDefault();
				const name = (document.getElementById('app-name') as HTMLInputElement).value.trim();
				const rawUrl = (document.getElementById('app-url') as HTMLInputElement).value.trim();
				const logo = (document.getElementById('app-logo') as HTMLInputElement).value.trim();
				const color = (document.getElementById('app-color') as HTMLInputElement).value;
				const catSelect = (document.getElementById('app-category') as HTMLSelectElement).value;
				const newCat = (document.getElementById('app-new-cat') as HTMLInputElement).value.trim();
				const errorEl = document.getElementById('form-error') as HTMLElement;

				const category = catSelect === '__new__' ? newCat : catSelect;

				if (!name) { showFormError('Please enter a name.'); return; }
				if (!rawUrl) { showFormError('Please enter a URL.'); return; }
				if (!category) { showFormError('Please enter a category name.'); return; }

				let url = rawUrl;
				if (!url.startsWith('http://') && !url.startsWith('https://')) url = 'https://' + url;
				try { new URL(url); } catch { showFormError('Invalid URL.'); return; }

				errorEl.style.display = 'none';

				const appFullscreen = (document.getElementById('app-fullscreen') as HTMLInputElement).checked;
				const app: CustomApp = {
					id: crypto.randomUUID(),
					name, url, logo, color, category, fullscreen: appFullscreen,
				};
				const apps = loadCustomApps();
				apps.push(app);
				saveCustomApps(apps);
				renderCustomApps();
				closeModal('modal-add-app');
			});

			function showFormError(msg: string) {
				const el = document.getElementById('form-error') as HTMLElement;
				el.textContent = msg;
				el.style.display = 'block';
			}
		</script>
	</body>
</html>

<style is:global>
	*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

	:root {
		--bg: #0A0A0F;
		--surface: rgba(255, 255, 255, 0.04);
		--border: rgba(255, 255, 255, 0.08);
		--text: #F8FAFC;
		--muted: #94a3b8;
		--red: #E50914;
	}

	body {
		background-color: var(--bg);
		color: var(--text);
		font-family: var(--font-geist), 'Noto Color Emoji', system-ui, sans-serif;
		min-height: 100dvh;
		-webkit-font-smoothing: antialiased;
		overflow-x: hidden;
	}

	::-webkit-scrollbar { width: 4px; }
	::-webkit-scrollbar-track { background: transparent; }
	::-webkit-scrollbar-thumb { background: rgba(255, 255, 255, 0.15); border-radius: 2px; }
	::-webkit-scrollbar-thumb:hover { background: rgba(255, 255, 255, 0.25); }

	/* ── Ambient background ── */
	.ambient {
		position: fixed;
		inset: 0;
		pointer-events: none;
		z-index: 0;
		overflow: hidden;
	}

	.blob {
		position: absolute;
		border-radius: 50%;
		filter: blur(120px);
		opacity: 0.18;
	}

	.blob-1 {
		width: 600px; height: 600px;
		background: #E50914;
		top: -200px; left: -100px;
	}

	.blob-2 {
		width: 500px; height: 500px;
		background: #312E81;
		bottom: -150px; right: -100px;
	}

	.blob-3 {
		width: 400px; height: 400px;
		background: #0EA5E9;
		top: 40%; left: 50%;
		transform: translate(-50%, -50%);
		opacity: 0.08;
	}

	/* ── Layout ── */
	main {
		position: relative;
		z-index: 1;
		max-width: 1800px;
		margin: 0 auto;
		padding: 0.4rem 2.5rem;
	}

	/* ── Header ── */
	header {
		display: grid;
		grid-template-columns: 1fr auto 1fr;
		align-items: center;
		margin-bottom: 0.6rem;
	}

	.logo {
		grid-column: 2;
		justify-self: center;
		margin: 0;
		line-height: 0;
	}

	.logo-img {
		height: clamp(7rem, 18vw, 16rem);
		width: auto;
		object-fit: contain;
		filter: drop-shadow(0 0 40px rgba(229, 9, 20, 0.5));
	}

	.header-right {
		grid-column: 3;
		justify-self: end;
		display: flex;
		flex-direction: column;
		align-items: flex-end;
		gap: 0.5rem;
	}

	.lang-btn {
		display: flex;
		align-items: center;
		gap: 0.3rem;
	}

	.lang-btn svg {
		width: 10px;
		height: 10px;
		flex-shrink: 0;
	}

	.locale-section-label {
		font-size: 0.7rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--muted);
		margin: 1rem 0 0.5rem;
	}

	.locale-section-label:first-of-type {
		margin-top: 0.25rem;
	}

	.locale-section-desc {
		font-size: 0.75rem;
		color: var(--muted);
		margin: -0.25rem 0 0.5rem;
		line-height: 1.4;
	}

	.locale-grid {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
	}

	.locale-option,
	.locale-country {
		background: rgba(255, 255, 255, 0.05);
		border: 1px solid rgba(255, 255, 255, 0.08);
		color: var(--muted);
		font-family: inherit;
		font-size: 0.8rem;
		font-weight: 500;
		padding: 0.4rem 0.75rem;
		border-radius: 8px;
		cursor: pointer;
		transition: background 120ms ease, color 120ms ease, border-color 120ms ease;
		white-space: nowrap;
	}

	.locale-option:hover,
	.locale-country:hover {
		background: rgba(255, 255, 255, 0.1);
		color: var(--text);
		border-color: rgba(255, 255, 255, 0.15);
	}

	.locale-option.is-active,
	.locale-country.is-active {
		color: var(--text);
		background: rgba(229, 9, 20, 0.18);
		border-color: rgba(229, 9, 20, 0.4);
	}

	@media (max-width: 768px) {
		header {
			grid-template-columns: 1fr 1fr;
			grid-template-rows: auto auto;
			row-gap: 1.25rem;
		}

		.logo {
			grid-column: 1 / -1;
			grid-row: 1;
		}

		.header-actions {
			grid-column: 1;
			grid-row: 2;
			justify-self: start;
		}

		header .header-right {
			grid-column: 2;
			grid-row: 2;
			justify-self: end;
			align-items: flex-end;
		}
	}

	@media (max-width: 480px) {
		.header-actions {
			gap: 0.35rem;
		}
	}

	/* ── Drag & drop ── */
	.drag-handle {
		display: inline-flex;
		align-items: center;
		padding: 2px 4px;
		margin-right: 0.5rem;
		border-radius: 4px;
		color: #334155;
		cursor: grab;
		transition: color 150ms ease;
		vertical-align: middle;
		touch-action: none;
	}

	.drag-handle:hover { color: #94a3b8; }
	.drag-handle:active { cursor: grabbing; }

	.drag-handle svg {
		width: 14px;
		height: 14px;
		display: block;
	}

	.category.is-dragging {
		opacity: 0.35;
	}

	/* Ghost element during touch drag */
	:global(.touch-ghost) {
		position: fixed;
		z-index: 999;
		pointer-events: none;
		opacity: 0.85;
		box-shadow: 0 20px 60px rgba(0,0,0,0.6);
		border-radius: 12px;
		background: #0A0A0F;
		overflow: hidden;
	}

	/* ── URL Launcher ── */
	.launcher-wrap {
		margin-bottom: 2.5rem;
	}

	/* ── Categories ── */
	.category {
		margin-bottom: 2.5rem;
	}

	.category-title {
		font-size: 0.75rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: #94a3b8;
		margin-bottom: 1rem;
		padding-left: 0.25rem;
		border-left: 3px solid #E50914;
		padding-left: 0.75rem;
	}

	/* ── Grid ── */
	.grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
		gap: 1.25rem;
	}

	/* Large screens (Tesla ~1920px) */
	@media (min-width: 1400px) {
		.grid {
			grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
			gap: 1.5rem;
		}
	}

	/* Tablet / landscape */
	@media (max-width: 768px) {
		.grid {
			grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
			gap: 1rem;
		}
	}

	/* Small mobile */
	@media (max-width: 480px) {
		.grid {
			grid-template-columns: repeat(2, 1fr);
			gap: 0.75rem;
		}
	}

	/* ── Card ── */
	.card {
		--mouse-x: 50%;
		--mouse-y: 50%;
		--app-color: #fff;

		position: relative;
		border-radius: 20px;
		background: var(--surface);
		border: 1px solid var(--border);
		backdrop-filter: blur(16px);
		-webkit-backdrop-filter: blur(16px);
		overflow: hidden;
		text-decoration: none;
		cursor: pointer;
		transition: transform 200ms ease, box-shadow 200ms ease, border-color 200ms ease;
		aspect-ratio: 1;
		/* Minimum tap target size */
		min-height: 160px;
	}

	.card:hover .card-inner { opacity: 1; }

	.card:hover {
		transform: scale(1.04) translateY(-3px);
		border-color: color-mix(in srgb, var(--app-color) 50%, transparent);
		box-shadow:
			0 0 0 1px color-mix(in srgb, var(--app-color) 20%, transparent),
			0 24px 48px -12px color-mix(in srgb, var(--app-color) 35%, transparent),
			0 0 100px -20px color-mix(in srgb, var(--app-color) 20%, transparent);
	}

	.card:active,
	.card.touching {
		transform: scale(0.96);
	}

	.card.touching .spotlight {
		opacity: 1;
	}

	.card.touching .border-glow {
		opacity: 1;
	}

	/* Spotlight radial gradient follows cursor */
	.spotlight {
		position: absolute;
		inset: 0;
		opacity: 0;
		transition: opacity 300ms ease;
		background: radial-gradient(
			circle at var(--mouse-x) var(--mouse-y),
			color-mix(in srgb, var(--app-color) 15%, transparent) 0%,
			transparent 60%
		);
		pointer-events: none;
		border-radius: inherit;
	}

	.card:hover .spotlight {
		opacity: 1;
	}

	/* Animated border glow */
	.border-glow {
		position: absolute;
		inset: -1px;
		border-radius: inherit;
		background: radial-gradient(
			circle at var(--mouse-x) var(--mouse-y),
			color-mix(in srgb, var(--app-color) 40%, transparent),
			transparent 60%
		);
		opacity: 0;
		transition: opacity 300ms ease;
		pointer-events: none;
		z-index: -1;
	}

	.card:hover .border-glow {
		opacity: 1;
	}

	/* Card content */
	.card-inner {
		position: relative;
		z-index: 1;
		display: flex;
		flex-direction: column;
		align-items: center;
		opacity: 0.82;
		transition: opacity 200ms ease;
		justify-content: center;
		gap: 1rem;
		height: 100%;
		padding: 1.5rem;
	}

	.icon-wrap {
		display: flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
	}

	.icon-wrap img {
		width: 80px;
		height: 80px;
		object-fit: contain;
		transition: transform 200ms ease;
	}

	.card:hover .icon-wrap img {
		transform: scale(1.08);
	}

	.icon-fallback {
		display: none;
		align-items: center;
		justify-content: center;
		width: 80px;
		height: 80px;
		font-size: 3rem;
		font-weight: 700;
	}

	.app-name {
		font-size: 1rem;
		font-weight: 600;
		color: rgba(248, 250, 252, 0.9);
		text-align: center;
		line-height: 1.3;
		letter-spacing: 0.02em;
	}

	@media (min-width: 1400px) {
		.icon-wrap img { width: 100px; height: 100px; }
		.icon-fallback { width: 100px; height: 100px; font-size: 3.5rem; }
		.app-name { font-size: 1.1rem; }
		.card-inner { gap: 1.25rem; padding: 2rem; }
	}

	@media (max-width: 480px) {
		.icon-wrap img { width: 60px; height: 60px; }
		.icon-fallback { width: 60px; height: 60px; font-size: 2.25rem; }
		.app-name { font-size: 0.875rem; }
	}

	/* ── Footer ── */
	footer {
		margin-top: 3rem;
		margin-bottom: 1.5rem;
		text-align: center;
		font-size: 1rem;
		color: rgba(248, 250, 252, 0.65);
		letter-spacing: 0.02em;
	}

	.footer-inner {
		display: flex;
		align-items: center;
		justify-content: center;
		flex-wrap: wrap;
		gap: 0.5rem 0.9rem;
	}

	.footer-sep {
		opacity: 0.3;
	}

	.footer-link {
		color: rgba(248, 250, 252, 0.65);
		text-decoration: none;
		transition: color 150ms ease;
	}

	.footer-link:hover {
		color: var(--text);
	}

	.footer-github {
		display: flex;
		align-items: center;
		gap: 0.4rem;
		color: rgba(248, 250, 252, 0.65);
		text-decoration: none;
		transition: color 150ms ease;
	}

	.footer-github:hover {
		color: var(--text);
	}

	.footer-github svg {
		width: 18px;
		height: 18px;
		flex-shrink: 0;
	}

	.footer-oss {
		font-size: 0.8rem;
		font-weight: 600;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		background: rgba(255, 255, 255, 0.08);
		border: 1px solid rgba(255, 255, 255, 0.12);
		border-radius: 6px;
		padding: 0.15rem 0.45rem;
	}

	/* ── FAB ── */
	.fab-wrap {
		position: fixed;
		bottom: 2rem;
		right: 2rem;
		z-index: 40;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.6rem;
	}

	@keyframes fab-bounce {
		0%, 20%, 100%  { transform: translateY(0); }
		6%             { transform: translateY(-10px); }
		12%            { transform: translateY(-2px); }
		17%            { transform: translateY(-6px); }
	}

	.fab-tooltip {
		position: relative;
		background: rgba(255, 255, 255, 0.07);
		border: 1px solid rgba(255, 255, 255, 0.12);
		backdrop-filter: blur(16px);
		-webkit-backdrop-filter: blur(16px);
		color: var(--text);
		font-size: 0.8rem;
		font-weight: 600;
		letter-spacing: 0.03em;
		white-space: nowrap;
		padding: 0.5rem 1rem;
		border-radius: 10px;
		box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4);
		animation: fab-bounce 7s ease-in-out infinite;
	}

	.fab-tooltip-arrow {
		position: absolute;
		bottom: -8px;
		left: 50%;
		transform: translateX(-50%);
		width: 12px;
		height: 8px;
		display: block;
	}

	@keyframes fab-ping {
		75%, 100% { transform: scale(1.8); opacity: 0; }
	}

	.fab-ping {
		position: absolute;
		inset: 0;
		border-radius: 50%;
		background: rgba(229, 9, 20, 0.4);
		animation: fab-ping 1.8s cubic-bezier(0, 0, 0.2, 1) infinite;
		pointer-events: none;
	}

	.fab {
		position: relative;
		width: 72px;
		height: 72px;
		border-radius: 50%;
		background: #E50914;
		border: none;
		color: #fff;
		cursor: pointer;
		display: flex;
		align-items: center;
		justify-content: center;
		box-shadow: 0 8px 28px rgba(229, 9, 20, 0.45);
		transition: transform 150ms ease, box-shadow 150ms ease, background 150ms ease;
	}

	.fab:hover {
		transform: scale(1.08);
		background: #f0141e;
		box-shadow: 0 14px 36px rgba(229, 9, 20, 0.6);
	}

	.fab:active { transform: scale(0.95); }

	.fab svg { width: 30px; height: 30px; }

	/* ── Card delete button ── */
	.card-delete {
		position: absolute;
		top: 0.5rem;
		right: 0.5rem;
		z-index: 2;
		width: 28px;
		height: 28px;
		border-radius: 50%;
		background: rgba(0, 0, 0, 0.6);
		border: 1px solid rgba(255, 255, 255, 0.15);
		color: rgba(255, 255, 255, 0.6);
		cursor: pointer;
		display: flex;
		align-items: center;
		justify-content: center;
		opacity: 0;
		transition: opacity 150ms ease, background 150ms ease, color 150ms ease;
	}

	.card:hover .card-delete,
	.card.touching .card-delete { opacity: 1; }

	.card-delete:hover {
		background: rgba(229, 9, 20, 0.8);
		color: #fff;
		border-color: transparent;
	}

	.card-delete svg { width: 12px; height: 12px; }

	/* ── EV Charging Calculator ── */
	.charger-modal-title {
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}

	.charger-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 0.75rem 1rem;
		margin-bottom: 1.5rem;
	}

	.charger-field {
		display: flex;
		flex-direction: column;
		gap: 0.4rem;
	}

	.charger-field--full { grid-column: 1 / -1; }

	.charger-input-wrap {
		position: relative;
		display: flex;
		align-items: center;
	}

	.charger-input-wrap .form-input { padding-right: 3.5rem; }

	.charger-unit {
		position: absolute;
		right: 0.75rem;
		font-size: 0.72rem;
		color: var(--muted);
		pointer-events: none;
		font-weight: 600;
		letter-spacing: 0.03em;
	}

	/* Dual range slider */
	.dual-range-wrap {
		position: relative;
		height: 44px;
		display: flex;
		align-items: center;
		margin-top: 0.5rem;
	}

	.dual-range-track {
		position: absolute;
		width: 100%;
		height: 5px;
		border-radius: 4px;
		background: rgba(255, 255, 255, 0.1);
		pointer-events: none;
	}

	.dual-range-fill {
		position: absolute;
		height: 100%;
		background: linear-gradient(90deg, #94a3b8, #34d399);
		border-radius: 4px;
	}

	.dual-range {
		position: absolute;
		width: 100%;
		height: 44px; /* full touch-target height */
		-webkit-appearance: none;
		appearance: none;
		background: transparent;
		pointer-events: none;
		outline: none;
		touch-action: none;
	}

	.dual-range::-webkit-slider-thumb {
		-webkit-appearance: none;
		width: 28px;
		height: 28px;
		border-radius: 50%;
		cursor: pointer;
		pointer-events: all;
		border: 2px solid rgba(255, 255, 255, 0.3);
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.5);
		transition: transform 120ms ease, box-shadow 120ms ease;
	}

	.dual-range::-webkit-slider-thumb:active { transform: scale(1.2); }

	.dual-range--lower::-webkit-slider-thumb { background: #94a3b8; }
	.dual-range--upper::-webkit-slider-thumb {
		background: #34d399;
		box-shadow: 0 0 10px rgba(52, 211, 153, 0.5);
	}

	.dual-range::-moz-range-thumb {
		width: 28px;
		height: 28px;
		border-radius: 50%;
		cursor: pointer;
		pointer-events: all;
		border: 2px solid rgba(255, 255, 255, 0.3);
	}

	.dual-range--lower::-moz-range-thumb { background: #94a3b8; }
	.dual-range--upper::-moz-range-thumb { background: #34d399; }

	.charger-range-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		margin-bottom: 0.25rem;
	}

	.charger-range-values {
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}

	.charger-range-val {
		display: flex;
		flex-direction: column;
		align-items: flex-end;
		font-size: 0.82rem;
		font-weight: 700;
		line-height: 1.2;
	}

	.charger-range-val--current { color: #94a3b8; }
	.charger-range-val--target  { color: #34d399; }
	.charger-range-arrow        { color: var(--muted); font-size: 0.8rem; }
	.charger-range-kwh          { font-size: 0.68rem; font-weight: 400; opacity: 0.7; }

	.charger-results {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 0.75rem;
	}

	.charger-stat {
		background: rgba(255, 255, 255, 0.04);
		border: 1px solid rgba(255, 255, 255, 0.08);
		border-radius: 14px;
		padding: 1rem 1.1rem;
		display: flex;
		flex-direction: column;
		gap: 0.4rem;
	}

	.charger-stat-label {
		font-size: 0.68rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.07em;
		color: var(--muted);
	}

	.charger-stat-value {
		font-size: 1.5rem;
		font-weight: 700;
		color: var(--text);
		line-height: 1;
	}

	/* ── Add App Form ── */
	.form-row {
		display: flex;
		flex-direction: column;
		gap: 0.4rem;
		margin-bottom: 1rem;
	}

	.form-row:last-child { margin-bottom: 0; }

	.form-row-split {
		display: grid;
		grid-template-columns: 1fr auto;
		gap: 0.75rem;
		align-items: end;
		margin-bottom: 1rem;
	}

	.form-label {
		font-size: 0.75rem;
		font-weight: 600;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--muted);
	}

	.form-required { color: #E50914; }
	.form-optional { font-weight: 400; text-transform: none; letter-spacing: 0; font-size: 0.7rem; }

	.form-input {
		background: rgba(255, 255, 255, 0.05);
		border: 1px solid rgba(255, 255, 255, 0.1);
		border-radius: 10px;
		color: var(--text);
		font-family: inherit;
		font-size: 0.9rem;
		padding: 0.65rem 0.9rem;
		outline: none;
		transition: border-color 150ms ease, box-shadow 150ms ease;
		width: 100%;
	}

	.form-input:focus {
		border-color: rgba(255, 255, 255, 0.25);
		box-shadow: 0 0 0 3px rgba(229, 9, 20, 0.15);
	}

	.form-input::placeholder { color: #475569; }

	.form-select { cursor: pointer; color-scheme: dark; }
	.form-select option   { background: #12121c; color: #F8FAFC; }
	.form-select optgroup { background: #0a0a0f; color: #94a3b8; font-style: normal; }

	.form-color {
		width: 44px;
		height: 44px;
		border-radius: 10px;
		border: 1px solid rgba(255, 255, 255, 0.1);
		background: transparent;
		padding: 2px;
		cursor: pointer;
		flex-shrink: 0;
	}

	.form-row--toggle {
		align-items: flex-start;
	}

	.toggle-switch {
		display: flex;
		align-items: center;
		gap: 0.6rem;
		cursor: pointer;
		user-select: none;
	}

	.toggle-switch input {
		position: absolute;
		opacity: 0;
		width: 0;
		height: 0;
	}

	.toggle-track {
		position: relative;
		width: 36px;
		height: 20px;
		background: rgba(255, 255, 255, 0.1);
		border-radius: 999px;
		border: 1px solid rgba(255, 255, 255, 0.12);
		transition: background 200ms ease, border-color 200ms ease;
		flex-shrink: 0;
	}

	.toggle-switch input:checked + .toggle-track {
		background: rgba(229, 9, 20, 0.5);
		border-color: rgba(229, 9, 20, 0.6);
	}

	.toggle-thumb {
		position: absolute;
		top: 2px;
		left: 2px;
		width: 14px;
		height: 14px;
		background: #94a3b8;
		border-radius: 50%;
		transition: transform 200ms ease, background 200ms ease;
	}

	.toggle-switch input:checked ~ .toggle-track .toggle-thumb {
		transform: translateX(16px);
		background: #fff;
	}

	.toggle-hint {
		font-size: 0.75rem;
		color: var(--muted);
		line-height: 1.3;
	}

	.form-error {
		font-size: 0.8rem;
		color: #f87171;
		margin-bottom: 0.75rem;
		padding-left: 0.25rem;
	}

	.form-actions {
		display: flex;
		justify-content: flex-end;
		gap: 0.6rem;
		margin-top: 1.25rem;
	}

	.form-btn {
		font-family: inherit;
		font-size: 0.85rem;
		font-weight: 600;
		padding: 0.6rem 1.25rem;
		border-radius: 10px;
		border: none;
		cursor: pointer;
		transition: background 150ms ease, transform 150ms ease;
	}

	.form-btn:active { transform: scale(0.97); }

	.form-btn-cancel {
		background: rgba(255, 255, 255, 0.07);
		color: var(--muted);
		border: 1px solid rgba(255, 255, 255, 0.1);
	}

	.form-btn-cancel:hover { background: rgba(255, 255, 255, 0.12); color: var(--text); }

	.form-btn-submit {
		background: rgba(255, 255, 255, 0.1);
		color: #fff;
		border: 1px solid rgba(255, 255, 255, 0.15);
		backdrop-filter: blur(16px);
		-webkit-backdrop-filter: blur(16px);
	}

	.form-btn-submit:hover {
		background: rgba(255, 255, 255, 0.18);
		border-color: rgba(255, 255, 255, 0.25);
	}

	/* ── Reduced motion ── */
	@media (prefers-reduced-motion: reduce) {
		.card { transition: none; }
		.spotlight, .border-glow { transition: none; }
		.fab-tooltip { animation: none; }
	}

	/* ── Touch devices: disable spotlight and blur for performance ── */
	@media (pointer: coarse) {
		.spotlight,
		.border-glow {
			display: none;
		}

		.card {
			backdrop-filter: none;
			-webkit-backdrop-filter: none;
		}

		.fab-tooltip {
			backdrop-filter: none;
			-webkit-backdrop-filter: none;
		}

		.modal-overlay {
			backdrop-filter: none;
			-webkit-backdrop-filter: none;
		}

		.modal-box {
			backdrop-filter: none;
			-webkit-backdrop-filter: none;
		}

		.header-btn {
			backdrop-filter: none;
			-webkit-backdrop-filter: none;
		}

		.form-btn-submit {
			backdrop-filter: none;
			-webkit-backdrop-filter: none;
		}

		.project-btn {
			backdrop-filter: none;
			-webkit-backdrop-filter: none;
		}
	}

	/* ── Header action buttons ── */
	.header-actions {
		grid-column: 1;
		justify-self: start;
		display: flex;
		flex-direction: column;
		align-items: stretch;
		gap: 0.4rem;
	}

	.header-actions-row {
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}

	.header-btn {
		background: var(--surface);
		border: 1px solid var(--border);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		color: var(--muted);
		font-family: inherit;
		font-size: 0.7rem;
		font-weight: 600;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		padding: 0.65rem 1rem;
		border-radius: 999px;
		cursor: pointer;
		transition: color 150ms ease, border-color 150ms ease, background 150ms ease, transform 150ms ease;
	}

	.header-btn:hover {
		color: var(--text);
		border-color: rgba(255, 255, 255, 0.2);
		background: rgba(255, 255, 255, 0.07);
		transform: scale(1.03);
	}

	.header-btn:active { transform: scale(0.97); }

	.header-btn--support {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
		width: 100%;
		color: #c084fc;
		border-color: rgba(168, 85, 247, 0.35);
	}

	.header-btn--support:hover {
		color: #c084fc;
		border-color: rgba(168, 85, 247, 0.5);
		background: rgba(168, 85, 247, 0.07);
		transform: scale(1.03);
	}

	.header-btn--charger {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.4rem;
		color: #34d399;
		border-color: rgba(52, 211, 153, 0.35);
		background: rgba(52, 211, 153, 0.07);
		padding: 0.55rem 1rem;
		font-size: 0.8rem;
		font-weight: 600;
		width: 100%;
		margin-top: 0.3rem;
	}

	.header-btn--charger:hover {
		color: #6ee7b7;
		border-color: rgba(52, 211, 153, 0.6);
		background: rgba(52, 211, 153, 0.12);
	}

	@keyframes lightning-flicker {
		0%, 100% { filter: drop-shadow(0 0 2px #facc15); opacity: 1; }
